@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: #fff;
    --foreground: #070e1c;
    --card: #fff;
    --card-foreground: #070e1c;
    --popover: #fff;
    --popover-foreground: #070e1c;
    --primary: #fd9117;
    --primary-foreground: #fff;
    --secondary: #f3f4f6;
    --secondary-foreground: #070e1c;
    --muted: #f3f4f6;
    --muted-foreground: #6b7280;
    --accent: #fd9117;
    --accent-foreground: #fff;
    --destructive: #ef4444;
    --destructive-foreground: #fff;
    --border: #e5e7eb;
    --input: #e5e7eb;
    --ring: #fd9117;
    --radius: .5rem;
  }

  .dark {
    --background: #070e1c;
    --foreground: #f3f4f6;
    --card: #070e1c;
    --card-foreground: #f3f4f6;
    --popover: #070e1c;
    --popover-foreground: #f3f4f6;
    --primary: #fd9117;
    --primary-foreground: #fff;
    --secondary: #1f2937;
    --secondary-foreground: #f3f4f6;
    --muted: #1f2937;
    --muted-foreground: #9ca3af;
    --accent: #fd9117;
    --accent-foreground: #fff;
    --destructive: #ef4444;
    --destructive-foreground: #fff;
    --border: #374151;
    --input: #374151;
    --ring: #fd9117;
  }
}
